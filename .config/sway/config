# Philips Consumer Electronics Company
# Name: PHL24M1N3200Z
# Mode: User Define
# RGB: 100, 95, 92
# Brightness: 65
# Contrast:   50
# Sharpness:  50
# Gamma:      2.2

output * bg #c1b5aa solid_color
output * adaptive_sync on
output DP-1 mode --custom 1920x1080@120.00Hz position 0,0

seat seat0 xcursor_theme "macOS-Monterey-White"
exec gsettings set org.gnome.desktop.interface cursor-theme "macOS-Monterey-White"

set $mod Mod4
set $alt Mod1

input type:keyboard {
    repeat_delay 200
    repeat_rate 50
}

input "type:pointer" {
	accel_profile "flat"
	pointer_accel "0"
}

gaps left 172
gaps right 388
gaps top 158
gaps bottom 98
default_border pixel 0
hide_edge_borders both
floating_modifier $mod normal
for_window [app_id=".*"] floating enable, titlebar hide
for_window [app_id=foot] max_render_time 1

bindsym $mod+z exec foot -e bash --rcfile $ENV
bindsym $mod+s exec grim -g "$(slurp)" \
-- $HOME/inv/ACM/$(date +%F-%H-%M-%S).jpg
bindsym $mod+y exec grim -c -g "0,0 1920x1080" \
-- $HOME/inv/ACM/$(date +%F-%H-%M-%S).jpg
bindsym $mod+u exec "$HOME/.local/share/Steam/steamapps/common/Aseprite/aseprite"
bindsym $mod+n exec firefox
bindsym $mod+b exec chromium --enable-features=UseOzonePlatform --ozone-platform=wayland
bindsym $mod+v exec steam
bindsym $mod+e exec swaymsg resize set 350px 400px
bindsym $mod+r exec swaymsg resize set 620px 750px
bindsym $mod+Shift+c reload
bindsym $mod+Shift+q exit
bindsym $mod+c kill
bindsym $mod+a fullscreen
bindsym $mod+f floating toggle
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
