set $mod Mod4
set $alt Mod1
output VGA-1 mode --custom 1920x1080@59Hz

input type:keyboard {
    repeat_delay 200
    repeat_rate 50
}

# Tiling Profile
gaps left 172
gaps right 388
gaps top 158
gaps bottom 98

bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+up focus up
bindsym $mod+down focus down
bindsym $mod+left focus left
bindsym $mod+right focus right
bindsym Shift+up move up 25 px
bindsym Shift+down move down 25 px
bindsym Shift+left move left 25 px
bindsym Shift+right move right 25 px
bindsym $mod+r exec swaymsg resize set 766px 820px
bindsym $mod+e exec swaymsg resize set 480px 420px
bindsym $mod+d exec swaymsg resize set 420px 480px
bindsym $mod+t exec swaymsg resize set 550px 320px

## SwayFX Configuration Options
#corner_radius 0
#shadows enable
#shadow_blur_radius 4
#shadows_on_csd disable
#blur disable
#blur_radius 2 # gaps right was 344

default_border pixel 0
default_floating_border none
hide_edge_borders smart
smart_borders no

font pango:Cherry Medium 0
floating_modifier $mod normal

for_window [app_id=".*"] floating enable, titlebar hide
for_window [title="Alacritty"] floating none, \
titlebar_padding 0 0, border pixel 8
for_window [title="Firefox"] titlebar_padding 0 0, border pixel 8
for_window [title="nsxiv"] titlebar_padding 0 0, border pixel 8

## Stylist Profile
#for_window [title="nsxiv"] title_format "<span></span>", \
#titlebar_padding 10 14, border normal 0
#for_window [title="mpv"] title_format "<span></span>", \
#titlebar_padding 10 14, border normal 0

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10
bindsym $mod+Shift+c reload
bindsym $mod+Shift+q exit
bindsym $mod+c kill
bindsym $mod+a fullscreen
bindsym $mod+f floating toggle

# Launcher Profile
bindsym $mod+0 exec amixer -c 1 -q set Master 5%+
bindsym $mod+9 exec amixer -c 1 -q set Master 5%-
bindsym $mod+n exec firefox
bindsym $mod+z exec alacritty -e bash --rcfile $ENV
bindsym $mod+Shift+z exec foot bash --rcfile $ENV
bindsym $mod+s exec grim -t png -g "$(slurp)" \
-- $HOME/screenshots/$(date +%F-%H-%M-%S).png

# Startup Profile
workspace 1
exec firefox

exec swww init
exec swww img ~/resources/caramel.png
# Previous Commands:
#   exec_always sh -c "killall yambar; yambar &"

## SAVED COLORS                           99826b (color1)
## CLASS COLOR           725d35 (color0), b29f89 (color1)
set $color0 #efcf9e
set $color1 #514036

## CLASS                1. brd   2. bg    3. txt   4. ind   5. chd
client.focused          $color1  $color1  $color1  $color1  $color1
client.focused_inactive $color1  $color1  $color1  $color1  $color1
client.unfocused        $color1  $color1  $color1  $color1  $color1
client.urgent           $color0  $color0  $color0  $color0  $color0
