#!/bin/sh

export NNN_USE_EDITOR=1
export NNN_COLORS=1683
export NNN_FCOLORS=c1e20b02006005f7c6d6abc4
export NNN_OPENER=$HOME/.local/share/bin/nnnopen
export NNN_BMS="a:$HOME/;b:$HOME/.local/share/;0:/dev/null
;c:$HOME/.config/;d:$HOME/Downloads/;m:/mnt/;v:$HOME/.vim/"
export NNN_PLUG='1:wallpaper;2:nmount \
;y:-!echo $PWD/$nnn|wl-copy*;a:imgview;'

/usr/bin/nnn -C "$@"
