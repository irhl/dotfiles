#!/bin/sh

EXTRACT="7z x"
BROWSER="firefox"
TERM="foot -e"
IMAGE="mpv"
VIDEO="mpv"
MUSIC="mpv --script=$HOME/.config/mpv/common/piko.lua "

case "${1##*.}" in
    html | docx | doc | pdf)
        $BROWSER "$1"
        ;;
    png | jpe | jpg | jpeg | avif | webp | gifv | gif)
        $IMAGE "$1" "$PWD"
        ;;
    webm | mp4 | mkv)
        $VIDEO "$1"
        ;;
    opus | mp3 | flv)
        $TERM $MUSIC "$1"
        ;;
    *)
        $TERM vim "$1"
        ;;
esac
