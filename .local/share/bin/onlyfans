#!/bin/sh

# onlyfans - cpu freq utils &
#            gpu fan controller

gpu_fan_enable() {
    chmod 777 /sys/class/hwmon/hwmon0/pwm1_enable
    chmod 777 /sys/class/hwmon/hwmon0/pwm1

    printf '%s' 1 > /sys/class/hwmon/hwmon0/pwm1_enable
    printf '%s' 80 > /sys/class/hwmon/hwmon0/pwm1
}

gpu_fan_control() {
    '0-250' 2> /dev/null

    read -r val
    printf '%s' "$val" > /sys/class/hwmon/hwmon0/pwm1
}

cpu_boost() {
    '0-1' 2> /dev/null

    read -r val
    printf '%s' "$val" > /sys/devices/system/cpu/cpufreq/boost
}

cpu_scaling_governor() {
    gov=/sys/devices/system/cpu/cpu0/cpufreq/scaling_available_governors
    cpu=/sys/devices/system/cpu/cpu0/cpufreq/scaling_governor

    # Check if 777 permissions was set
    if [ $(stat -c %a "$cpu") != '777' ]
    then
        chmod 777 \
	/sys/devices/system/cpu/cpu*/cpufreq/scaling_governor
    fi

    # Show available governor options.
    read -r sel < "$gov"

    # Don't stack debug output.
    set +x
    printf '%s\n' "$sel"

    # Back to normal debug output.
    set -x

    # Select governor option.
    read -r sel

    # Apply changes.
    printf '%s' "$sel" | tee \
	/sys/devices/system/cpu/cpu*/cpufreq/scaling_governor
}

main() {
    if [ "$USER" != "root" ]
    then
        printf '%s\n' "[onlyfans] sudo is required."
        return 0
    fi

    # Debug/Trace execution of commands.
    set -x

    # (*) -> default
    case "${1}" in
      -e) gpu_fan_enable
          ;;
      -c) gpu_fan_control
          ;;
      -b) cpu_boost
          ;;
      -g) cpu_scaling_governor
          ;;
       *)
          ;;
    esac
}

main "$1"
