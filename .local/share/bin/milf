#!/bin/sh

DETACH="bb"
EXTRACT="7z x"
BROWSER="firefox"
TERM="footclient -e"
IMAGE="nsxiv -s F -z 25 -t -a"
VIDEO="mpvi"
MUSIC="piko"


case "${1##*.}" in
    html | docx | doc | pdf)
        $DETACH $BROWSER "$1"
        ;;
    png | jpe | jpg | jpeg | avif | webp | gifv | gif)
        $DETACH $IMAGE "$1" "$PWD"
        ;;
    webm | mp4 | mkv)
        $VIDEO "$1"
        ;;
    opus | mp3 | flv)
        $DETACH $TERM $MUSIC "$1"
        ;;
    *)
        $DETACH $TERM vim "$1"
        ;;
esac
